# S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Optional Custom S3 Endpoint (e.g., Cloudflare R2, MinIO, Wasabi, B2)
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Optional Force Path-Style S3 URL addressing (Required by MinIO/LocalStack)
# AWS_S3_FORCE_PATH_STYLE=true

# Optional Web Server Configuration (Default is 8000)
PORT=8000

# Admin Panel Token configuration
ADMIN_TOKEN=testadmin123
